@model List<TripModel>
@{
    ViewData["Title"] = "My assigned trips";
}

<h2>My assigned trips today</h2>

@if (!Model.Any())
{
    <p class="text-muted">No trips assigned for today.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Capacity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trip in Model)
            {
                <tr>
                    <td>@trip.TripDate.ToString("d")</td>
                    <td>@trip.TripStatus</td>
                    <td>@trip.CapacityUsed / @trip.MaxCapacitySnapshot</td>
                    <td><a class="btn btn-sm btn-outline-primary" asp-controller="Driver" asp-action="TripDetails" asp-route-id="@trip.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
}
