@model TripModel
@{
    ViewData["Title"] = "Trip details";
}

<h2>Trip on @Model.TripDate.ToString("d")</h2>

<dl class="row">
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.TripStatus</dd>
    <dt class="col-sm-3">Capacity</dt>
    <dd class="col-sm-9">@Model.CapacityUsed / @Model.MaxCapacitySnapshot</dd>
    <dt class="col-sm-3">Started</dt>
    <dd class="col-sm-9">@(Model.StartedAtUtc?.ToString("g") ?? "—")</dd>
    <dt class="col-sm-3">Ended</dt>
    <dd class="col-sm-9">@(Model.EndedAtUtc?.ToString("g") ?? "—")</dd>
</dl>

<form asp-controller="Driver" asp-action="Start" asp-route-id="@Model.Id" method="post" class="d-inline">
    <button type="submit" class="btn btn-success">Start trip</button>
</form>
<form asp-controller="Driver" asp-action="End" asp-route-id="@Model.Id" method="post" class="d-inline">
    <button type="submit" class="btn btn-secondary">End trip</button>
</form>
<a class="btn btn-outline-danger" asp-controller="Driver" asp-action="ReportIncident" asp-route-id="@Model.Id">Report incident</a>
