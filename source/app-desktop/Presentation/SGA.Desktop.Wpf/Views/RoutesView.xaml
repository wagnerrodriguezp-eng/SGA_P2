<UserControl x:Class="SGA.Desktop.Wpf.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Routes &amp; Schedules" FontSize="20" FontWeight="Bold" />
                    <Button Content="NEW ROUTE" Command="{Binding NewCommand}" HorizontalAlignment="Right"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </DockPanel>
                <DataGrid ItemsSource="{Binding Routes}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding RouteStatus}" Width="100" />
                        <DataGridTemplateColumn Header="" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Open"
                                            Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Padding="16" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Route details" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             materialDesign:HintAssist.Hint="Name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" MaxLength="500"
                             materialDesign:HintAssist.Hint="Description" AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
                    <ComboBox ItemsSource="{Binding RouteStatusOptions}" SelectedItem="{Binding RouteStatus}"
                              materialDesign:HintAssist.Hint="Status" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ValidationErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="SAVE" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0" />
                        <Button Content="CLOSE" Command="{Binding CancelEditCommand}" Style="{StaticResource MaterialDesignFlatButton}" />
                    </StackPanel>

                    <Separator Margin="0,0,0,12" />
                    <TextBlock Text="Stops" FontWeight="Bold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Stops}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Order, StringFormat='{}{0}. '}" FontWeight="Bold">
                                    <Run Text=" " />
                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox Text="{Binding NewStopName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             materialDesign:HintAssist.Hint="New stop name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" />
                    <TextBox Text="{Binding NewStopOrder, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Order" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" />
                    <Button Content="ADD STOP" Command="{Binding AddStopCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,16" />

                    <Separator Margin="0,0,0,12" />
                    <TextBlock Text="Schedules" FontWeight="Bold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Schedules}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DepartureTime}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox Text="{Binding NewScheduleDepartureTime, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Departure time (hh:mm:ss)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" />
                    <TextBox Text="{Binding NewScheduleDaysOfWeekMask, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Days mask (Mon=1,Tue=2,Wed=4,Thu=8,Fri=16,Sat=32,Sun=64)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" />
                    <Button Content="ADD SCHEDULE" Command="{Binding AddScheduleCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</UserControl>
