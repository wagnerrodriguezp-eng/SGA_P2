<UserControl x:Class="SGA.Desktop.Wpf.Views.TripAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="16">
        <StackPanel MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Assign Trip" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

            <ComboBox ItemsSource="{Binding Routes}" SelectedItem="{Binding SelectedRoute}" DisplayMemberPath="Name"
                      materialDesign:HintAssist.Hint="Route" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />
            <ComboBox ItemsSource="{Binding Schedules}" SelectedItem="{Binding SelectedSchedule}" DisplayMemberPath="DepartureTime"
                      materialDesign:HintAssist.Hint="Schedule (departure time)" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />
            <ComboBox ItemsSource="{Binding Buses}" SelectedItem="{Binding SelectedBus}" DisplayMemberPath="PlateNumber"
                      materialDesign:HintAssist.Hint="Bus" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />
            <ComboBox ItemsSource="{Binding Drivers}" SelectedItem="{Binding SelectedDriver}" DisplayMemberPath="LicenseNumber"
                      materialDesign:HintAssist.Hint="Driver" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />
            <DatePicker SelectedDate="{Binding TripDate}" materialDesign:HintAssist.Hint="Trip date" Margin="0,0,0,16" />

            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,12" />

            <Button Content="ASSIGN TRIP" Command="{Binding AssignCommand}" Style="{StaticResource MaterialDesignRaisedButton}" />
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,16,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </materialDesign:Card>
</UserControl>
