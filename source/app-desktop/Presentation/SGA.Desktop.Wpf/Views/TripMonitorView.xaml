<UserControl x:Class="SGA.Desktop.Wpf.Views.TripMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="16">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Trip Monitor" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,24,0" />
                <DatePicker SelectedDate="{Binding FromDate}" materialDesign:HintAssist.Hint="From" Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding ToDate}" materialDesign:HintAssist.Hint="To" Margin="0,0,8,0" />
                <Button Content="REFRESH" Command="{Binding LoadCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Text="{Binding CancelReason, UpdateSourceTrigger=PropertyChanged}" Width="300"
                         materialDesign:HintAssist.Hint="Cancellation reason (used by the Cancel button below)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,12" />

            <DataGrid ItemsSource="{Binding Trips}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding TripDate}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding TripStatus}" Width="120" />
                    <DataGridTextColumn Header="Capacity" Width="120">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="CapacityUsed" />
                                <Binding Path="MaxCapacitySnapshot" />
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Started" Binding="{Binding StartedAtUtc}" Width="160" />
                    <DataGridTextColumn Header="Ended" Binding="{Binding EndedAtUtc}" Width="160" />
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Cancel"
                                        Command="{Binding DataContext.CancelTripCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:Card>
</UserControl>
