<UserControl x:Class="SGA.Desktop.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="16">
        <StackPanel MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Provision Student / Employee / Driver Account" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" MaxLength="256"
                     materialDesign:HintAssist.Hint="Email" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                     materialDesign:HintAssist.Hint="First name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                     materialDesign:HintAssist.Hint="Last name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
            <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Role}"
                      materialDesign:HintAssist.Hint="Role" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" />
            <TextBox Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"
                     materialDesign:HintAssist.Hint="Student code (Students only)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
            <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"
                     materialDesign:HintAssist.Hint="Employee code (Employees only)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
            <TextBox Text="{Binding LicenseNumber, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"
                     materialDesign:HintAssist.Hint="License number (Drivers only)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,16" />

            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,12" />

            <Button Content="PROVISION ACCOUNT" Command="{Binding ProvisionCommand}" Style="{StaticResource MaterialDesignRaisedButton}" />
            <ProgressBar IsIndeterminate="True" Height="2" Margin="0,16,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </materialDesign:Card>
</UserControl>
