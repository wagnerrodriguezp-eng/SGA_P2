<UserControl x:Class="SGA.Desktop.Wpf.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="16">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Audit Log" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <DatePicker SelectedDate="{Binding FromDate}" materialDesign:HintAssist.Hint="From" Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding ToDate}" materialDesign:HintAssist.Hint="To" Margin="0,0,8,0" />
                <TextBox Text="{Binding UserIdInput, UpdateSourceTrigger=PropertyChanged}" Width="220"
                         materialDesign:HintAssist.Hint="User Id (GUID)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0" />
                <TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Width="200"
                         materialDesign:HintAssist.Hint="Action contains…" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0" />
                <Button Content="SEARCH" Command="{Binding SearchCommand}" Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,12" />

            <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp (UTC)" Binding="{Binding TimestampUtc}" Width="160" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="160" />
                    <DataGridTextColumn Header="Entity" Binding="{Binding EntityName}" Width="120" />
                    <DataGridTextColumn Header="Entity Id" Binding="{Binding EntityId}" Width="220" />
                    <DataGridTextColumn Header="User Id" Binding="{Binding UserId}" Width="220" />
                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:Card>
</UserControl>
