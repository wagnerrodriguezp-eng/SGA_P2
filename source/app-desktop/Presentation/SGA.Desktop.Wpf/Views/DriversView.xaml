<UserControl x:Class="SGA.Desktop.Wpf.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Driver Management" FontSize="20" FontWeight="Bold" />
                    <Button Content="NEW DRIVER" Command="{Binding NewCommand}" HorizontalAlignment="Right"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </DockPanel>
                <DataGrid ItemsSource="{Binding Drivers}" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectedItem="{Binding SelectedDriver}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="License Number" Binding="{Binding LicenseNumber}" Width="*" />
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*" />
                        <DataGridTextColumn Header="User Id" Binding="{Binding UserId}" Width="220" />
                        <DataGridTemplateColumn Header="" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Edit" Margin="2"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Deactivate" Margin="2"
                                                Command="{Binding DataContext.DeactivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Padding="16" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Driver details" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />
                <TextBox Text="{Binding LicenseNumber, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"
                         materialDesign:HintAssist.Hint="License number" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" MaxLength="20"
                         materialDesign:HintAssist.Hint="Phone number" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />

                <Separator Margin="0,4,0,12" />
                <TextBlock Text="New driver account (ignored when editing)" FontSize="11" Opacity="0.7" Margin="0,0,0,8" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" MaxLength="256"
                         materialDesign:HintAssist.Hint="Email" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                         materialDesign:HintAssist.Hint="First name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                         materialDesign:HintAssist.Hint="Last name" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12" />

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ValidationErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="SAVE" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0" />
                    <Button Content="CANCEL" Command="{Binding CancelEditCommand}" Style="{StaticResource MaterialDesignFlatButton}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
