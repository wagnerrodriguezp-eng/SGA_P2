<Window x:Class="SGA.Desktop.Wpf.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="SGA-ITLA — Transport Administrator" Height="480" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <materialDesign:Card Margin="24" Padding="24" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="SGA-ITLA" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Transport Administrator" FontSize="14" Opacity="0.7"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />

                <TextBox x:Name="EmailBox"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" />

                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             PasswordChanged="OnPasswordChanged"
                             Margin="0,0,0,8" />

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ValidationErrorBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,8"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}" />

                <Button Content="LOG IN" Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,8,0,0" />

                <ProgressBar IsIndeterminate="True" Height="2" Margin="0,16,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
